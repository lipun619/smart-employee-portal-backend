{
  "AllowedHosts": "*",

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },

  "AzureKeyVault": {
    "VaultUri": ""
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Database": {
    "RunMigrationsOnStartup": false
  },

  "Diagnostics": {
    "ExposeDetailedErrors": false
  }
}

